    "base_multiplier": 1.060,
    "decay_rate": 0.0075,
    "decay_offset": 55,
    "level_0_xp": 50,
    "level_1_xp": 100,
    "base_xp": 100,
    "description": "Level N≥2: 100 × ∏(1.060 - 0.0075*(k-2)/(k+55)) for k=2..N. Level 10 ≈ 969 XP, Level 20 ≈ 2201 XP."
  },
  "skill_xp_formula": {
    "governs": "skill_level_up",
    "type": "compound",
    "base_multiplier": 1.030,
    "decay_rate": 0.0050,
    "decay_offset": 55,
    "level_0_xp": 50,
    "level_1_xp": 100,
    "base_xp": 100,
    "description": "Same curve as player levels but lower slope. Skill level 10 costs ~182 days at 5 skill XP/day."
  },
  "skill_projection_tiers": [
    { "min": 0.30, "max": 0.39, "multiplier": 0.1 },
    { "min": 0.40, "max": 0.49, "multiplier": 0.2 },
    { "min": 0.50, "max": 0.59, "multiplier": 0.3 },
