    { "min": 0.70, "max": 0.79, "multiplier": 0.5 },
    { "min": 0.80, "max": 0.89, "multiplier": 0.6 },
    { "min": 0.90, "max": 0.99, "multiplier": 0.7 },
    { "min": 1.00, "max": 1.00, "multiplier": 0.8 }
